{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.wonderfulcrew.com" }],
      "destination": "https://wonderfulcrew.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "functions": {
    "api/ai.js": {
      "maxDuration": 30
    },
    "api/stt.js": {
      "maxDuration": 30
    },
    "api/reconcile-subscriptions.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/reconcile-subscriptions",
      "schedule": "0 * * * *"
    }
  ]
}
