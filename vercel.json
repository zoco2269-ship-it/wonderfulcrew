{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    }
  ],
  "functions": {
    "api/ai.js": {
      "maxDuration": 30
    },
    "api/stt.js": {
      "maxDuration": 30
    },
    "api/reconcile-subscriptions.js": {
      "maxDuration": 60
    },
    "api/generate-sns-content.js": {
      "maxDuration": 60
    },
    "api/sns-publish.js": {
      "maxDuration": 60
    },
    "api/marketing-push-cron.js": {
      "maxDuration": 60
    },
    "api/seo-ping.js": {
      "maxDuration": 30
    },
    "api/email-campaign-cron.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/reconcile-subscriptions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/generate-sns-content?count=10",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/sns-publish",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/marketing-push-cron",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/seo-ping",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/email-campaign-cron",
      "schedule": "0 9 * * *"
    }
  ]
}
